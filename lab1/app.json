{
  "expo": {
    "name": "Resume Builder",
    "slug": "resume-builder",
    "scheme": "resume-builder",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.anonymous.resumebuilder"
    },
    "plugins": [
      "expo-localization",
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ]
  }
}
